{
    "name": "cybershield-platform",
    "version": "1.0.0",
    "description": "Enterprise-Grade Security Operations Platform",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "test": "cross-env NODE_ENV=test jest --coverage",
        "test:watch": "cross-env NODE_ENV=test jest --watch",
        "test:auth": "cross-env NODE_ENV=test jest tests/auth.test.js",
        "test:middleware": "cross-env NODE_ENV=test jest tests/middleware.test.js",
        "test:database": "cross-env NODE_ENV=test jest tests/database.test.js",
        "lint": "eslint src/",
        "format": "prettier --write \"src/**/*.js\"",
        "build": "echo 'Build complete'"
    },
    "keywords": [
        "security",
        "monitoring",
        "threat-detection",
        "incident-management"
    ],
    "author": "CyberShield Team",
    "license": "MIT",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dompurify": "^3.4.2",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.0.0",
        "express-validator": "^7.3.2",
        "helmet": "^7.0.0",
        "http": "^0.0.1-security",
        "jsonwebtoken": "^9.0.1",
        "mongoose": "^9.6.1",
        "morgan": "^1.10.0",
        "qrcode": "^1.5.4",
        "socket.io": "^4.6.1",
        "speakeasy": "^2.0.0"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "eslint": "^8.50.0",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^11.1.0",
        "nodemon": "^3.0.1",
        "prettier": "^3.0.3",
        "supertest": "^7.2.2"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ],
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/server.js"
        ],
        "coverageDirectory": "coverage",
        "coverageReporters": [
            "text",
            "lcov",
            "html"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/tests/setup.js"
        ]
    },
    "engines": {
        "node": ">=16.0.0"
    }
}