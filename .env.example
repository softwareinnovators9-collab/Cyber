# Production Environment Variables
# Copy this file to .env and fill in your values

# Application
NODE_ENV=production
PORT=3000

# Database
MONGODB_URI=mongodb://username:password@localhost:27017/cybershield
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=your_secure_password
MONGODB_DATABASE=cybershield
MONGODB_PORT=27017

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_key_here
COOKIE_SECRET=your_super_secure_cookie_secret_key_here

# CORS
CORS_ORIGIN=https://yourdomain.com

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Security Features
MFA_ENABLED=true
ACCOUNT_LOCKOUT_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (Optional)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Threat Simulation (Disabled by default for production)
THREAT_SIMULATION_ENABLED=false